        return np.sqrt((eta1 - eta2)**2 + dphi**2)

    dR_j1 = deltaR(ph_eta, ph_phi, j1.eta, j1.phi)
    dR_j2 = deltaR(ph_eta, ph_phi, j2.eta, j2.phi)

    outside_jets = (dR_j1 > 0.4) & (dR_j2 > 0.4)

    # ------------------------------------------------------------
    # Final photon selection: inside ellipse AND outside jets
    # ------------------------------------------------------------
    final_mask = inside_ellipse & outside_jets

    ph_eta_in = ph_eta[final_mask]
    ph_phi_in = ph_phi[final_mask]
    ph_pt_in  = ph_pt[final_mask]


    # ------------------------------------------------------------
    # Invariant mass of photons inside ellipse
    # ------------------------------------------------------------
    if len(ph_pt_in) > 0:
        ph_px = ph_pt_in * np.cos(ph_phi_in)
        ph_py = ph_pt_in * np.sin(ph_phi_in)
        ph_pz = ph_pt_in * np.sinh(ph_eta_in)
        ph_E  = ph_pt_in * np.cosh(ph_eta_in)

        ph_px_sum = np.sum(ph_px)
        ph_py_sum = np.sum(ph_py)
        ph_pz_sum = np.sum(ph_pz)
