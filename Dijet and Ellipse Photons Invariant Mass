        arg = ph_E_sum**2 - (ph_px_sum**2 + ph_py_sum**2 + ph_pz_sum**2)
        arg = max(arg, 0)
        M_ph = np.sqrt(arg)
    else:
        M_ph = 0.0

    # ------------------------------------------------------------
    # Fill histogram with M(jj) + M(photons)
    # ------------------------------------------------------------
    h.fill(mass=M_jj + M_ph)

# ------------------------------------------------------------
# Plot histogram
# ------------------------------------------------------------
fig, ax = plt.subplots(figsize=(8,6))
hep.histplot(h, ax=ax)
ax.set_xlabel("Invariant Mass [GeV]")
ax.set_ylabel("Events")
ax.set_title("Dijet + Ellipse Photons Invariant Mass")
plt.show()
