                ((ph_phi - f1[1] + np.pi) % (2*np.pi) - np.pi)**2)

    dist2 = np.sqrt((ph_eta - f2[0])**2 +
                ((ph_phi - f2[1] + np.pi) % (2*np.pi) - np.pi)**2)

